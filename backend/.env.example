# Django
DJANGO_SECRET_KEY=change-me-to-a-long-random-string
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,.ondigitalocean.app,rapidscuba.com,www.rapidscuba.com

# Database — leave unset for SQLite (dev). On Digital Ocean, set to the managed DB connection string.
# DATABASE_URL=postgres://user:password@host:5432/dbname

# CORS — origins allowed to POST to the API. Comma-separated.
DJANGO_CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Email notifications on new inquiry/booking. Leave INQUIRY_NOTIFY_TO empty to disable.
INQUIRY_NOTIFY_TO=info@rapidscuba.com
INQUIRY_NOTIFY_FROM=no-reply@rapidscuba.com
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=True
